{
  "name": "tool-call-contract",
  "version": "0.0.0",
  "description": "Define AI tool contracts once, then validate calls and generate test artifacts.",
  "type": "module",
  "bin": {
    "tool-call-contract": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean",
    "format": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "tools",
    "contracts",
    "zod",
    "testing"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.8.2",
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  }
}
